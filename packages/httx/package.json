{
  "name": "@stacksjs/httx",
  "type": "module",
  "version": "0.1.9",
  "description": "A modern command-line & library HTTP client, for the API era.",
  "author": "Chris Breuer <chris@stacksjs.org>",
  "license": "MIT",
  "homepage": "https://github.com/stacksjs/ts-http",
  "repository": {
    "type": "git",
    "url": "https://github.com/stacksjs/ts-http"
  },
  "bugs": {
    "url": "https://github.com/stacksjs/ts-http/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "module": "./dist/src/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "httx": "./dist/bin/cli.js",
    "http": "./dist/bin/cli.js",
    "https": "./dist/bin/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build.ts",
    "compile": "bun build ./bin/cli.ts --compile --minify --outfile bin/httx",
    "prepublishOnly": "bun run build",
    "test": "bun test",
    "typecheck": "bun tsc --noEmit"
  },
  "dependencies": {
    "ts-error-handling": "^0.1.0"
  }
}
