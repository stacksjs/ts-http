{
  "name": "@stacksjs/httx-dashboard",
  "type": "module",
  "version": "0.1.10",
  "description": "A real-time monitoring dashboard for httx HTTP client, built with stx.",
  "author": "Chris Breuer <chris@stacksjs.org>",
  "license": "MIT",
  "homepage": "https://github.com/stacksjs/ts-http",
  "repository": {
    "type": "git",
    "url": "https://github.com/stacksjs/ts-http"
  },
  "bugs": {
    "url": "https://github.com/stacksjs/ts-http/issues"
  },
  "keywords": [
    "httx",
    "dashboard",
    "monitoring",
    "stx",
    "http-client",
    "metrics"
  ],
  "bin": {
    "httx-dashboard": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js"
    },
    "./*": {
      "import": "./dist/*"
    }
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "LICENSE.md",
    "README.md",
    "dist"
  ],
  "scripts": {
    "build": "bun --bun build.ts",
    "dev": "bun --watch server.ts",
    "prepublishOnly": "bun run build",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "typecheck": "bun tsc --noEmit"
  },
  "dependencies": {
    "@cwcss/crosswind": "^0.2.6",
    "@stacksjs/httx": "^0.1.7",
    "bunfig": "^0.5.0",
    "ts-broadcasting": "^0.0.5"
  },
  "devDependencies": {
    "@stacksjs/stx": "^0.2.5",
    "bun-plugin-stx": "^0.2.5"
  }
}
