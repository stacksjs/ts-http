{
  "name": "@stacksjs/httx",
  "type": "module",
  "version": "0.1.10",
  "private": true,
  "description": " A modern command-line & library HTTP client, for the API era. Like httpie, written in & for TypeScript.",
  "author": "Chris Breuer <chris@stacksjs.org>",
  "license": "MIT",
  "homepage": "https://github.com/stacksjs/httx",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stacksjs/httx.git"
  },
  "bugs": {
    "url": "https://github.com/stacksjs/httx/issues"
  },
  "keywords": [
    "api",
    "requests",
    "cli",
    "library",
    "httpie",
    "bun",
    "stacks",
    "typescript",
    "javascript"
  ],
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun --bun packages/httx/build.ts",
    "compile": "bun build ./packages/httx/bin/cli.ts --compile --minify --outfile bin/httx",
    "compile:all": "bun run compile:linux-x64 && bun run compile:linux-arm64 && bun run compile:windows-x64 && bun run compile:darwin-x64 && bun run compile:darwin-arm64",
    "compile:linux-x64": "bun build ./packages/httx/bin/cli.ts --compile --minify --target=bun-linux-x64 --outfile bin/httx-linux-x64",
    "compile:linux-arm64": "bun build ./packages/httx/bin/cli.ts --compile --minify --target=bun-linux-arm64 --outfile bin/httx-linux-arm64",
    "compile:windows-x64": "bun build ./packages/httx/bin/cli.ts --compile --minify --target=bun-windows-x64 --outfile bin/httx-windows-x64.exe",
    "compile:darwin-x64": "bun build ./packages/httx/bin/cli.ts --compile --minify --target=bun-darwin-x64 --outfile bin/httx-darwin-x64",
    "compile:darwin-arm64": "bun build ./packages/httx/bin/cli.ts --compile --minify --target=bun-darwin-arm64 --outfile bin/httx-darwin-arm64",
    "fresh": "bunx rimraf node_modules/ bun.lock && bun i",
    "prepublishOnly": "bun --bun run build",
    "package:bin": "bun run compile:all && bun run zip",
    "test": "bun test",
    "lint": "bunx --bun pickier .",
    "lint:fix": "bunx --bun pickier . --fix",
    "format": "bunx --bun pickier . --format",
    "format:fix": "bunx --bun pickier . --format --write",
    "changelog": "bunx logsmith --verbose",
    "changelog:generate": "bunx logsmith --output CHANGELOG.md",
    "release": "bunx --bun bumpx prompt --recursive",
    "release:patch": "bunx --bun bumpx patch --recursive --yes",
    "publish:patch": "bunx --bun bumpx patch --recursive --yes",
    "release:minor": "bunx --bun bumpx minor --recursive --yes && cd packages/httx && bun publish",
    "release:major": "bunx --bun bumpx major --recursive --yes && cd packages/httx && bun publish",
    "typecheck": "bunx tsc --noEmit",
    "dev:docs": "bun --bun bunpress dev docs",
    "dev:devtools": "cd packages/devtools && bun serve.ts --port 4401",
    "build:docs": "bun --bun bunpress build docs",
    "preview:docs": "bun --bun bunpress preview docs",
    "zip": "bun run zip:all",
    "zip:all": "bun run zip:linux-x64 && bun run zip:linux-arm64 && bun run zip:windows-x64 && bun run zip:darwin-x64 && bun run zip:darwin-arm64",
    "zip:linux-x64": "zip -j bin/httx-linux-x64.zip bin/httx-linux-x64",
    "zip:linux-arm64": "zip -j bin/httx-linux-arm64.zip bin/httx-linux-arm64",
    "zip:windows-x64": "zip -j bin/httx-windows-x64.zip bin/httx-windows-x64.exe",
    "zip:darwin-x64": "zip -j bin/httx-darwin-x64.zip bin/httx-darwin-x64",
    "zip:darwin-arm64": "zip -j bin/httx-darwin-arm64.zip bin/httx-darwin-arm64"
  },
  "dependencies": {
    "@stacksjs/stx": "0.2.73",
    "stx-router": "0.2.73",
    "ts-broadcasting": "^0.0.5",
    "ts-error-handling": "^0.1.1"
  },
  "devDependencies": {
    "better-dx": "^0.2.15",
    "bunfig": "^0.15.14"
  },
  "git-hooks": {
    "pre-commit": {
      "staged-lint": {
        "*.{js,ts,json,yaml,yml,md}": "bunx --bun pickier lint --fix"
      },
      "autoRestage": true
    },
    "commit-msg": "bunx gitlint --edit .git/COMMIT_EDITMSG"
  }
}
